# ============================================================
# AUDITIT BY PWC — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# ============================================================

# MongoDB URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?appName=AppName

# JWT Configuration
JWT_SECRET=your-secret-key-min-32-characters

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP Email Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_STARTTLS_REQUIRED=true
SMTP_CONNECTION_TIMEOUT=10000
SMTP_TIMEOUT=10000
SMTP_WRITE_TIMEOUT=10000
SMTP_DEBUG=false
MAIL_FROM_NAME=AuditIT

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev
